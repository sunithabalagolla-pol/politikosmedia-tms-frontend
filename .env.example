# ─── Backend ──────────────────────────────────────────────────────────────────
# URL of your backend API server
VITE_BACKEND_URL=http://localhost:5000

# ─── Azure AD (optional — only needed if using Microsoft SSO) ─────────────────
# Azure App Registration → Overview → Application (client) ID
VITE_AZURE_CLIENT_ID=your-azure-client-id-here

# Azure App Registration → Overview → Directory (tenant) ID
VITE_AZURE_TENANT_ID=your-azure-tenant-id-here

# Must match the Redirect URI configured in your Azure App Registration
VITE_REDIRECT_URI=http://localhost:5173
